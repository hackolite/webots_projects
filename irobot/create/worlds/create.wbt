WorldInfo {
  info [
    "iRobot Create simulation in the Webots complete apartment."
    "The vacuum cleaner robots roam the apartment while a supervisor tracks their position and exposes a REST API."
    "A top-down god camera observes the whole apartment from the sky in 2D."
    "This apartment was sponsored by Kamal Othman & Prof. Ahmad Rad from AISL-SFU."
  ]
  title "iRobot Create - Complete Apartment"
  basicTimeStep 16
}
